# ── BUGate core .gitignore (SUT-neutral) ──

# Python
__pycache__/
*.py[cod]
*.egg-info/
build/
dist/
.venv/
venv/

# OS / editor
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp
*.swo

# Local agent + memory state — SUT-mounted, never part of core
.memory_bus/
.shared/memory/
.shared/progress/
.shared/memory-service-archive/
.codex/memories/
.claude/memory/
# Personal, per-clone Claude Code overrides — never committed (Claude Code
# ignores it globally too; this makes the ignore portable to every clone).
.claude/settings.local.json

# Secrets / environments — never commit
.env
.env.*
!.env.example
**/secrets.*
**/*.secret
*.pem
*.key
id_rsa*
*_keypair*
*mnemonic*

# Mounted SUTs live in their own repo/workspace, not in the core repo
/sut/

# Onboarding workbench is an output dir; only its README belongs in core
/.shared/skills/bugate/integration/workbench/*
!/.shared/skills/bugate/integration/workbench/README.md

# Logs / artifacts / temp
*.log
/artifacts/
/tmp/
*.tmp
*.bak

# Default report outputs from the scorers when run without explicit --*-output
# (oracle_falsification.py / check_prd_health.py / generate_assertion_coverage_matrix.py).
/oracle_falsification_result.json
/oracle_falsification_result.md
/prd_health_result.json
/prd_health_report.md
/assertion_coverage_matrix.md
/self_healing.json
/self_healing.md
/self_healing_repair_plan.md

# Only the engine repo's own root core config (a SUT repo commits its own).
/bugate.config.yaml
