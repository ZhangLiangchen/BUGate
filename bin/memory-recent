#!/usr/bin/env bash
# Newest agent-visible memories. Delegates to scripts/memory_bus.py recent.
set -euo pipefail

find_root() {
  local dir
  dir="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." 2>/dev/null && pwd || echo "$PWD")"
  while [ "$dir" != "/" ]; do
    if [ -f "$dir/AGENTS.md" ] && [ -d "$dir/.shared" ]; then
      echo "$dir"
      return 0
    fi
    dir="$(dirname "$dir")"
  done
  echo "$PWD"
}
ROOT="$(find_root)"
exec python3 "$ROOT/scripts/memory_bus.py" recent "$@"
