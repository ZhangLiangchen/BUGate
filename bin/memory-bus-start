#!/usr/bin/env bash
# Launch the local mcp-memory-service for BUGate.
#
# The memory bus is a REQUIRED BUGate component (long-term memory, dual-agent
# progress sync + relay, memory promotion) — not an optional add-on. This
# wrapper reuses a healthy machine-level service, or brings one up; if the
# `memory` binary is absent it INSTALLS it once into a machine-level venv
# (~/.bugate/venv) and pre-fetches the ONNX model, then launches. Git-free: the
# engine root is resolved from this script's own location.
#
# Escape hatch for locked-down/offline machines: set BUGATE_MEMORY_NO_INSTALL=1
# to skip the auto-install and only print the manual steps.
set -euo pipefail

# Engine root: bin/ sits one level below the engine tree root.
ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"

# System-level bus home: ONE machine-wide service/database shared by every
# workspace (namespace tags isolate projects). Any repo's wrapper resolves to
# the same dir, eliminating per-repo split-brain databases by construction.
# Resolution: MCP_MEMORY_BASE_DIR > BUGATE_MEMORY_HOME > ~/.bugate/memory-bus.
export MCP_MEMORY_BASE_DIR="${MCP_MEMORY_BASE_DIR:-${BUGATE_MEMORY_HOME:-$HOME/.bugate/memory-bus}}"
export MCP_MEMORY_STORAGE_BACKEND="${MCP_MEMORY_STORAGE_BACKEND:-sqlite_vec}"

# Reuse-first: if a healthy memory service already answers on the target port,
# reuse it and exit — N governed repos share ONE machine-level instance
# (namespace tags isolate projects), so start must never spawn a duplicate.
# This also avoids `memory launch`'s own conflict path, which trusts only its
# pid file and would KILL a live listener whose pid file went stale.
if python3 "$ROOT/scripts/memory_bus.py" status --json >/dev/null 2>&1; then
  echo "memory-bus-start: healthy memory service already running on 127.0.0.1:${MCP_HTTP_PORT:-8000}; reusing the machine-level shared instance."
  exit 0
fi
# PyTorch-free embeddings via ONNX. The model must already exist under
# ~/.cache/mcp_memory/onnx_models (pre-download once; the in-service downloader
# cannot traverse a socks all_proxy). Set MCP_MEMORY_USE_ONNX=0 to fall back.
export MCP_MEMORY_USE_ONNX="${MCP_MEMORY_USE_ONNX:-1}"
mkdir -p "$MCP_MEMORY_BASE_DIR"

# --- generate client API keys once (git-ignored) ----------------------------
if [ ! -f "$MCP_MEMORY_BASE_DIR/client.env" ]; then
  TOKEN="$(python3 - <<'PY'
import secrets
print(secrets.token_urlsafe(32))
PY
)"
  umask 077
  {
    printf 'MCP_API_KEY=%s\n' "$TOKEN"
    printf 'MCP_API_KEY_AGENT=%s\n' "$TOKEN"
    printf 'MCP_API_KEY_HUMAN=%s\n' "$TOKEN"
  } > "$MCP_MEMORY_BASE_DIR/client.env"
fi
set -a
. "$MCP_MEMORY_BASE_DIR/client.env"
set +a

# --- resolve the `memory` binary --------------------------------------------
# Order: engine-local .venv (self-development) > machine-level BUGate venv
# (shared by every imported repo, one install per machine) > PATH.
BUGATE_MEMORY_VENV="${BUGATE_MEMORY_VENV:-$HOME/.bugate/venv}"

resolve_memory_bin() {
  MEMORY_BIN=""
  for cand in "$ROOT/.venv/bin/memory" "$BUGATE_MEMORY_VENV/bin/memory"; do
    if [ -x "$cand" ]; then MEMORY_BIN="$cand"; return 0; fi
  done
  if command -v memory >/dev/null 2>&1; then MEMORY_BIN="$(command -v memory)"; return 0; fi
  return 1
}

resolve_memory_bin || true

# Auto-install once (machine-level) — the memory bus is required, so a missing
# binary is a setup gap to close, not an optional hint to print.
if [ -z "$MEMORY_BIN" ] && [ "${BUGATE_MEMORY_NO_INSTALL:-0}" != "1" ]; then
  echo "memory-bus-start: memory service not installed — installing the required BUGate memory runtime into $BUGATE_MEMORY_VENV (one-time, machine-level)..." >&2
  if python3 -m venv "$BUGATE_MEMORY_VENV" \
     && "$BUGATE_MEMORY_VENV/bin/python" -m pip install -q -U pip \
     && "$BUGATE_MEMORY_VENV/bin/python" -m pip install -q -U mcp-memory-service huggingface_hub numpy onnxruntime tokenizers; then
    # Pre-fetch the ONNX model with the venv's Hugging Face CLI (best-effort;
    # the service can also fetch on first use, or run with MCP_MEMORY_USE_ONNX=0).
    PATH="$BUGATE_MEMORY_VENV/bin:$PATH" "$ROOT/bin/memory-model-fetch" \
      || echo "memory-bus-start: ONNX model pre-fetch incomplete; the service will fetch on first use (or set MCP_MEMORY_USE_ONNX=0)." >&2
    resolve_memory_bin || true
  else
    echo "memory-bus-start: auto-install of mcp-memory-service failed (see pip output above)." >&2
  fi
fi

if [ -z "$MEMORY_BIN" ]; then
  cat >&2 <<HINT
memory-bus-start: the required memory service (mcp-memory-service) is not available.

Diagnose: confirm python3 + network are reachable, then install it once
(machine-level) and re-run:

  python3 -m venv "$BUGATE_MEMORY_VENV"
  "$BUGATE_MEMORY_VENV/bin/python" -m pip install -U mcp-memory-service huggingface_hub onnxruntime tokenizers
  PATH="$BUGATE_MEMORY_VENV/bin:\$PATH" "$ROOT/bin/memory-model-fetch"

Then: "$ROOT/bin/memory-bus-ensure". BUGate is incomplete without the memory bus
(no long-term memory, dual-agent sync/relay, or memory promotion).
HINT
  exit 1
fi

exec "$MEMORY_BIN" launch --host 127.0.0.1 --port "${MCP_HTTP_PORT:-8000}" "$@"
