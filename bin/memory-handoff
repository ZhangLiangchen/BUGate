#!/usr/bin/env bash
# Record a handoff to another agent. Delegates to memory_bus.py handoff.
set -euo pipefail

find_root() {
  local dir
  dir="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." 2>/dev/null && pwd || echo "$PWD")"
  while [ "$dir" != "/" ]; do
    if [ -f "$dir/AGENTS.md" ] && [ -d "$dir/.shared" ]; then
      echo "$dir"
      return 0
    fi
    dir="$(dirname "$dir")"
  done
  echo "$PWD"
}
ROOT="$(find_root)"
"$ROOT/bin/memory-bus-ensure" >/dev/null 2>&1 || true
exec python3 "$ROOT/scripts/memory_bus.py" handoff "$@"
