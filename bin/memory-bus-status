#!/usr/bin/env bash
# Show memory-service status. Delegates to scripts/memory_bus.py status.
# Git-free root via sentinel walk-up (AGENTS.md + .shared), pwd fallback.
set -euo pipefail

find_root() {
  local dir
  dir="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." 2>/dev/null && pwd || echo "$PWD")"
  while [ "$dir" != "/" ]; do
    if [ -f "$dir/AGENTS.md" ] && [ -d "$dir/.shared" ]; then
      echo "$dir"
      return 0
    fi
    dir="$(dirname "$dir")"
  done
  echo "$PWD"
}
ROOT="$(find_root)"

export MCP_MEMORY_BASE_DIR="${MCP_MEMORY_BASE_DIR:-$ROOT/.memory_bus}"
if [ -f "$MCP_MEMORY_BASE_DIR/client.env" ]; then
  set -a
  . "$MCP_MEMORY_BASE_DIR/client.env"
  set +a
fi
exec python3 "$ROOT/scripts/memory_bus.py" status "$@"
