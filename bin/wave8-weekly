#!/usr/bin/env bash
# Wave 8 periodic quality-evidence run (BUGate core, SUT-neutral).
#
# Re-runs oracle falsification on the current real evidence pool, then
# regenerates the assertion coverage matrix + Wave 8 audit from that result:
#   <REPORTS_DIR>/oracle_falsification_result.{json,md}
#   <REPORTS_DIR>/assertion_coverage_matrix.md
#
# The Wave 8 evidence glob is SUT-specific and is NOT hardcoded here. Supply it
# via the WAVE8_EVIDENCE_GLOB env var, or via the active BUGate profile/config
# key `wave8_evidence_glob` (the simple BUGate YAML parser flattens nested keys,
# so an indented `wave8:\n  evidence_glob: ...` block is read as `evidence_glob`
# or `wave8_evidence_glob`). If neither is set, this script prints a hint and
# exits non-zero rather than guessing a SUT path.
#
# Optional overrides:
#   WAVE8_FALSIFICATION_SPEC  Spec path (default: profile `falsification_spec`).
#   WAVE8_REPORTS_DIR         Output directory (default: profile `wave8_reports_dir`, else <WORKSPACE>/reports).
#   WAVE8_ARTIFACT_ROOT       Root scanned for 03_inventory.yaml (default: profile `wave8_artifact_root`, else <WORKSPACE>).
#   BUGATE_PROFILE            Profile path honored for config lookup and passed to both tools.
#   BUGATE_PROJECT_ROOT       Workspace override (else nearest ancestor with bugate.config.yaml, else the engine).
#
# Layout-aware: the ENGINE is where this script lives (core checkout, or the
# vendored kit inside a governed repo); the WORKSPACE is the governed repo root
# (bugate.config.yaml). All relative globs/paths/outputs resolve against the
# WORKSPACE so an imported repo's `docs/.../probes/*.json` glob and reports land
# in the SUT repo, never inside the vendored kit tree.
#
# Enable weekly automation with EITHER:
#   crontab (imported): 0 9 * * 1  cd <sut-repo> && .bugate/bin/wave8-weekly >> artifacts/wave8_weekly.log 2>&1
#   crontab (core):     0 9 * * 1  cd <bugate-checkout> && WAVE8_EVIDENCE_GLOB='...' bin/wave8-weekly >> reports/wave8_weekly.log 2>&1
#   launchd:  a LaunchAgent invoking this script with StartCalendarInterval (Weekday=1, Hour=9),
#             with WAVE8_EVIDENCE_GLOB set in the LaunchAgent's EnvironmentVariables.
#
# The run is offline (no live API calls, no test edits); git history dates
# successive reports.
set -euo pipefail

# Engine root: bin/ sits one level below the engine tree root.
ENGINE="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
# Workspace root: env override, else walk up from cwd to bugate.config.yaml,
# else fall back to the engine itself (standalone core checkout).
WORKSPACE="${BUGATE_PROJECT_ROOT:-}"
if [ -z "$WORKSPACE" ]; then
  probe="$(pwd)"
  while [ "$probe" != "/" ]; do
    if [ -f "$probe/bugate.config.yaml" ]; then WORKSPACE="$probe"; break; fi
    probe="$(dirname "$probe")"
  done
fi
WORKSPACE="${WORKSPACE:-$ENGINE}"
cd "$WORKSPACE"

# Resolve SUT-owned Wave 8 config: env vars win, else active profile/config
# (BUGATE_PROFILE honored, same precedence as the Python CLIs).
read_profile_value() {
  local key="$1"
  python3 - "$ENGINE" "$key" <<'PY'
import os
import sys
sys.path.insert(0, sys.argv[1] + "/scripts")
try:
    from bugate_core import load_config
    cfg = load_config(profile=os.environ.get("BUGATE_PROFILE") or None)
except Exception:
    cfg = {}
print(cfg.get(sys.argv[2]) or "")
PY
}

EVIDENCE_GLOB="${WAVE8_EVIDENCE_GLOB:-}"
if [ -z "$EVIDENCE_GLOB" ]; then
  EVIDENCE_GLOB="$(read_profile_value wave8_evidence_glob)"
fi
if [ -z "$EVIDENCE_GLOB" ]; then
  EVIDENCE_GLOB="$(read_profile_value evidence_glob)"
fi

if [ -z "$EVIDENCE_GLOB" ]; then
  cat >&2 <<'HINT'
[wave8-weekly] No Wave 8 evidence glob configured.

Set one of:
  * env var:  WAVE8_EVIDENCE_GLOB='<path/glob to real captured evidence JSON>'
  * config:   add `wave8_evidence_glob: '<glob>'` to bugate.config.yaml or your
              active SUT profile (the BUGate YAML parser also accepts a
              `wave8:` block with an indented `evidence_glob:` line).

The Wave 8 evidence glob is SUT-specific and is intentionally not hardcoded.
HINT
  exit 1
fi

SPEC_PATH="${WAVE8_FALSIFICATION_SPEC:-}"
if [ -z "$SPEC_PATH" ]; then
  SPEC_PATH="$(read_profile_value falsification_spec)"
fi

REPORTS_DIR="${WAVE8_REPORTS_DIR:-}"
if [ -z "$REPORTS_DIR" ]; then
  REPORTS_DIR="$(read_profile_value wave8_reports_dir)"
fi
REPORTS_DIR="${REPORTS_DIR:-$WORKSPACE/reports}"

ARTIFACT_ROOT="${WAVE8_ARTIFACT_ROOT:-}"
if [ -z "$ARTIFACT_ROOT" ]; then
  ARTIFACT_ROOT="$(read_profile_value wave8_artifact_root)"
fi
ARTIFACT_ROOT="${ARTIFACT_ROOT:-$WORKSPACE}"
mkdir -p "$REPORTS_DIR"

ORACLE_JSON="$REPORTS_DIR/oracle_falsification_result.json"
ORACLE_MD="$REPORTS_DIR/oracle_falsification_result.md"
MATRIX_MD="$REPORTS_DIR/assertion_coverage_matrix.md"

echo "[wave8-weekly] $(date -u +%FT%TZ) evidence glob: $EVIDENCE_GLOB"

oracle_args=(--evidence "$EVIDENCE_GLOB" --json-output "$ORACLE_JSON" --md-output "$ORACLE_MD")
if [ -n "$SPEC_PATH" ]; then
  oracle_args+=(--spec "$SPEC_PATH")
fi
if [ -n "${BUGATE_PROFILE:-}" ]; then
  oracle_args+=(--profile "$BUGATE_PROFILE")
fi
python3 "$ENGINE/scripts/oracle_falsification.py" "${oracle_args[@]}"

matrix_args=(
  --mutation-result "$ORACLE_JSON" \
  --artifact-root "$ARTIFACT_ROOT" \
  --output "$MATRIX_MD"
)
if [ -n "$SPEC_PATH" ]; then
  matrix_args+=(--spec "$SPEC_PATH")
fi
if [ -n "${BUGATE_PROFILE:-}" ]; then
  matrix_args+=(--profile "$BUGATE_PROFILE")
fi
python3 "$ENGINE/scripts/generate_assertion_coverage_matrix.py" "${matrix_args[@]}"

echo "[wave8-weekly] done. Review survived falsifications and bare/missing assertions:"
echo "  $ORACLE_MD"
echo "  $MATRIX_MD"
