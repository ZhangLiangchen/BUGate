#!/usr/bin/env bash
# Ensure the REQUIRED BUGate memory service is up; diagnose + bring it up if not.
# On a first-ever run memory-bus-start also installs it (machine-level, once),
# which can take minutes — that install proceeds in the background and this
# ensure reports it. Non-blocking by design: a transient memory outage must
# self-heal (restart), never block the user's edits/session.
# Engine root resolved from this script's own location.
set -euo pipefail

# Engine root: bin/ sits one level below the engine tree root.
ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"

LOG_FILE="${TMPDIR:-/tmp}/bugate-memory-bus.log"
PORT="${MCP_HTTP_PORT:-8000}"
MAX_WAIT_SECONDS="${MEMORY_BUS_ENSURE_WAIT_SECONDS:-8}"

health_ok() {
  python3 "$ROOT/scripts/memory_bus.py" status --json >/dev/null 2>&1
}

if health_ok; then
  exit 0
fi

mkdir -p "$(dirname "$LOG_FILE")"

# Avoid starting duplicate launchers when multiple hooks fire close together.
if ! pgrep -f "memory.*launch.*--port ${PORT}" >/dev/null 2>&1; then
  {
    printf '[%s] starting BUGate memory bus on 127.0.0.1:%s\n' "$(date '+%Y-%m-%d %H:%M:%S')" "$PORT"
    nohup "$ROOT/bin/memory-bus-start" >>"$LOG_FILE" 2>&1 &
  } >/dev/null 2>&1
fi

for _ in $(seq 1 "$MAX_WAIT_SECONDS"); do
  if health_ok; then
    printf 'Memory bus was not running; started successfully.\n'
    exit 0
  fi
  sleep 1
done

# Not up within the wait window. This is usually the one-time cold install (pip
# + ONNX model) still running in the background — not a hard failure. Diagnose
# loudly and let it finish; do NOT block the caller (self-heal, not fail-closed).
printf 'BUGate memory bus not up yet after %ss.\n' "$MAX_WAIT_SECONDS" >&2
printf '  - First run? The required memory service is likely still installing/starting in the background.\n' >&2
printf '  - Diagnose / watch:   tail -f %s\n' "$LOG_FILE" >&2
printf '  - Re-check shortly:   %s/bin/memory-bus-status\n' "$ROOT" >&2
printf '  - If it never comes up, run %s/bin/memory-bus-start directly to see the error.\n' "$ROOT" >&2
exit 0
